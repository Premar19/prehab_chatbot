{
  "metadata": {
    "name": "CKD Chatbot Gold-Standard Evaluation Set",
    "version": "1.0",
    "description": "Manually curated test set for evaluating retrieval quality of the NHS CKD chatbot RAG pipeline. Each question is annotated with the chunk IDs that should ideally be retrieved from the FAISS index to correctly answer it. Used to compute Recall@k, Mean Reciprocal Rank (MRR), and Precision@k.",
    "total_questions": 30,
    "categories": {
      "symptoms": 4,
      "diagnosis": 4,
      "treatment": 5,
      "prevention": 4,
      "lifestyle": 4,
      "causes": 3,
      "out_of_scope": 6
    },
    "query_types": {
      "direct": 13,
      "colloquial": 6,
      "out_of_scope": 6,
      "follow_up": 5
    },
    "notes": "Out-of-scope questions intentionally test the MIN_SCORE threshold — they should return NO relevant chunks and trigger the fallback response. Follow-up questions include a 'history' field to test contextualised retrieval."
  },

  "questions": [
    {
      "id": "q01",
      "category": "symptoms",
      "query_type": "direct",
      "question": "What are the symptoms of chronic kidney disease?",
      "expected_chunk_ids": [
