        "nhs-kidney-disease-symptoms-later-stages-of-ckd-011",
        "nhs-kidney-disease-symptoms-of-ckd-002"
      ]
    },
    {
      "id": "q02",
      "category": "symptoms",
      "query_type": "direct",
